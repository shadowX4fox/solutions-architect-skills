{
  "name": "sa-skills",
  "version": "3.14.7",
  "description": "Claude Code plugin for architecture documentation and compliance generation",
  "type": "module",
  "workspaces": ["tools/docgen"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "bundle:handoff-agent": "bun tools/bundle-handoff-agent.ts",
    "bundle:check": "bun tools/bundle-handoff-agent.ts --check"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.11",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
