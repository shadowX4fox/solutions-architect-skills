{
  "// MARKETPLACE REGISTRATION": "Register the shadowx4fox marketplace to install plugins",
  "extraKnownMarketplaces": {
    "shadowx4fox-solution-architect-marketplace": {
      "source": {
        "source": "github",
        "repo": "shadowX4fox/solutions-architect-skills"
      }
    }
  },

  "// PLUGIN INSTALLATION": "Enable the solutions-architect-skills plugin",
  "enabledPlugins": {
    "sa-skills@shadowx4fox-solution-architect-marketplace": true
  },

  "// PERMISSIONS": "Required for compliance generation agents — plugin agents cannot use permissionMode frontmatter",
  "// BASH": "bun (template expansion, utils, header detector CLI), date (contract timestamps), mkdir (compliance-docs dir)",
  "// FILE ACCESS": "Read/Write /tmp/* (template processing), Read/Write //tmp/architecture-explorer/sessions/** (architecture-explorer-headers session-edit tracker), Read/Write compliance-docs/* (contract output)",
  "// PLUGIN READ": "Skills read templates and guides from the plugin marketplace cache",
  "// AGENTS": "10 compliance generators + 10 validators + universal architecture-explorer (Haiku navigator, v3.16.0) + 3 reviewers (peer-review-category, architecture-analysis, principle-quality — v3.17.0) + handoff agents + docs export",
  "// WEBSEARCH": "Validators use WebSearch for EOL (end-of-life) technology version checks",
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(mkdir *)",
      "Bash(date *)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(awk:*)",
      "Bash(ls:*)",
      "Read(~/.claude/plugins/marketplaces/shadowx4fox-solution-architect-marketplace/**)",
      "Read(~/.claude/plugins/cache/shadowx4fox-solution-architect-marketplace/**)",
      "Glob(**/skills/architecture-compliance/SKILL.md)",
      "Glob(**/skills/architecture-dev-handoff/SKILL.md)",
      "Glob(~/.claude/plugins/marketplaces/shadowx4fox-solution-architect-marketplace/*)",
      "Read(//tmp/*)",
      "Write(//tmp/*)",
      "Write(compliance-docs/*)",
      "Read(compliance-docs/*)",
      "Agent(sa-skills:compliance-generator)",
      "Agent(sa-skills:business-continuity-validator)",
      "Agent(sa-skills:cloud-validator)",
      "Agent(sa-skills:data-ai-validator)",
      "Agent(sa-skills:development-validator)",
      "Agent(sa-skills:enterprise-validator)",
      "Agent(sa-skills:integration-validator)",
      "Agent(sa-skills:platform-validator)",
      "Agent(sa-skills:process-validator)",
      "Agent(sa-skills:security-validator)",
      "Agent(sa-skills:sre-validator)",
      "Agent(sa-skills:peer-review-category-agent)",
      "Agent(sa-skills:architecture-analysis-agent)",
      "Agent(sa-skills:principle-quality-reviewer)",
      "Agent(sa-skills:handoff-generator)",
      "Agent(sa-skills:handoff-asset-generator)",
      "Agent(sa-skills:handoff-context-builder)",
      "Agent(sa-skills:architecture-explorer)",
      "Agent(sa-skills:docs-export-generator)",
      "Bash(rm *)",
      "Write(exports/*)",
      "Read(exports/*)",
      "Write(analysis/*)",
      "Read(analysis/*)",
      "Write(handoffs/*)",
      "Read(handoffs/*)",
      "Write(handoffs/.manifest.json)",
      "Read(handoffs/.manifest.json)",
      "Write(//tmp/handoff-payloads/*)",
      "Read(//tmp/handoff-payloads/*)",
      "Write(//tmp/architecture-explorer/**)",
      "Read(//tmp/architecture-explorer/**)",
      "WebSearch"
    ]
  },

  "// HOOKS — v3.14.1+: session-scoped editlog tracker": "Records every Write/Edit on a docs/**/*.md file into /tmp/architecture-explorer/sessions/<projectHash>-<sessionId>.editlog. The /regenerate-explorer-headers --session slash command consumes the log and clears it on success. Cost per edit: ~10 ms (bun startup + JSONL append). The hook never blocks the user's edit.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "if": "Write(docs/**/*.md) OR Edit(docs/**/*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.claude/plugins/marketplaces/shadowx4fox-solution-architect-marketplace/skills/architecture-explorer-headers/utils/header-cli.ts session-log add \"$TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ]
  },

  "// USAGE NOTES": [
    "1. Copy this file to your project: cp .claude/settings.json.example /path/to/your/project/.claude/settings.json",
    "2. Remove the comment fields (lines starting with '//')",
    "3. Restart Claude Code to load the marketplace and plugin",
    "4. Verify installation: /plugin list"
  ]
}
