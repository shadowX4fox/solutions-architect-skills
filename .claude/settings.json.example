{
  "// MARKETPLACE REGISTRATION": "Register the shadowx4fox marketplace to install plugins",
  "extraKnownMarketplaces": {
    "shadowx4fox-solution-architect-marketplace": {
      "source": {
        "source": "github",
        "repo": "shadowX4fox/solutions-architect-skills"
      }
    }
  },

  "// PLUGIN INSTALLATION": "Enable the solutions-architect-skills plugin",
  "enabledPlugins": {
    "solutions-architect-skills@shadowx4fox-solution-architect-marketplace": true
  },

  "// PERMISSIONS": "Required for compliance generation agents — plugin agents cannot use permissionMode frontmatter",
  "// BASH PERMISSIONS": "bun with wildcard prefix handles absolute plugin paths; mkdir -p * covers any output dir",
  "// AGENT PERMISSIONS": "Agent() rules allow Claude to spawn compliance generators without manual prompts",
  "permissions": {
    "allow": [
      "Bash(bun */skills/architecture-compliance/utils/*)",
      "Bash(mkdir -p *)",
      "Bash(date *)",
      "Agent(solutions-architect-skills:business-continuity-compliance-generator)",
      "Agent(solutions-architect-skills:sre-compliance-generator)",
      "Agent(solutions-architect-skills:cloud-compliance-generator)",
      "Agent(solutions-architect-skills:data-ai-compliance-generator)",
      "Agent(solutions-architect-skills:development-compliance-generator)",
      "Agent(solutions-architect-skills:process-compliance-generator)",
      "Agent(solutions-architect-skills:security-compliance-generator)",
      "Agent(solutions-architect-skills:platform-compliance-generator)",
      "Agent(solutions-architect-skills:enterprise-compliance-generator)",
      "Agent(solutions-architect-skills:integration-compliance-generator)"
    ]
  },

  "// USAGE NOTES": [
    "1. Copy this file to your project: cp .claude/settings.json.example /path/to/your/project/.claude/settings.json",
    "2. Remove the comment fields (lines starting with '//')",
    "3. Restart Claude Code to load the marketplace and plugin",
    "4. Verify installation: /plugin list"
  ]
}
