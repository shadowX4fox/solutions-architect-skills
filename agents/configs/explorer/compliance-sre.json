      "case_insensitive": true,
      "severity": "desired"
    },
    {
      "name": "missing_observability_triad",
      "absent_pattern": "(metrics.*logs.*traces|observability triad)",
      "case_insensitive": true,
      "severity": "high"
    }
  ],
  "score_threshold": 0.3,
  "output_format": "v1",
  "notes": "Hand-tuned exemplar for SRE compliance (LASRE01-LASRE57, two-tier scoring 36 blockers + 21 desired). Required sections come from agents/configs/sre.json phase3.required_files. Boost weights tuned for SRE vocabulary — SLO/SLI/MTTR/error budget rank highest, runbook coverage is a desired gate, observability triad is a high-severity gap if absent."
