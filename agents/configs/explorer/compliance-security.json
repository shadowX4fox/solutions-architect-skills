  "gap_markers": [
    {
      "name": "missing_encryption_in_transit",
      "absent_pattern": "(TLS|HTTPS|encryption in transit)",
      "case_insensitive": true,
      "severity": "blocker"
    },
    {
      "name": "missing_encryption_at_rest",
      "absent_pattern": "(encryption at rest|AES|encrypted storage)",
      "case_insensitive": true,
      "severity": "blocker"
    },
    {
      "name": "missing_authentication",
      "absent_pattern": "(authentication|OAuth|JWT|SAML|OpenID|MFA)",
      "case_insensitive": true,
      "severity": "blocker"
    },
    {
      "name": "missing_secrets_management",
      "absent_pattern": "(secrets management|vault|KMS|key management)",
      "case_insensitive": true,
      "severity": "high"
